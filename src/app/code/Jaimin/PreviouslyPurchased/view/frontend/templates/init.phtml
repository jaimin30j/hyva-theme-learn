<script>
document.addEventListener('alpine:init', () => {
    Alpine.store('previouslyPurchased', {
        enabled: false,
        skus: [],
        label: 'Previously Purchased',
        init() {
            window.addEventListener(
                'private-content-loaded',
                (event) => {
                    const data =
                        event.detail.data['previously-purchased'];
                    if (!data) {
                        return;
                    }
                    this.enabled = data.enabled || false;
                    this.skus = data.skus || [];
                    this.label = data.label_text || 'Previously Purchased';
                }
            );
        },

        hasPurchased(sku) {
            if (!this.enabled) {
                return false;
            }
            return this.skus.includes(sku);
        }
    });
    Alpine.store('previouslyPurchased').init();
});
</script>